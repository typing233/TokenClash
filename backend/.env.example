# MongoDB配置
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=tokenclash

# 火山方舟API配置
VOLCANO_API_KEY=your_api_key_here
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 模型配置 - 用户可以配置多个模型
MODEL_1_NAME=doubao-seed-1.8b-chat
MODEL_1_DISPLAY_NAME=豆包小模型
MODEL_2_NAME=doubao-seed-12b-chat
MODEL_2_DISPLAY_NAME=豆包12B模型
MODEL_3_NAME=
MODEL_3_DISPLAY_NAME=
MODEL_4_NAME=
MODEL_4_DISPLAY_NAME=

# JWT配置（可选，用于用户认证）
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 服务器配置
HOST=0.0.0.0
PORT=8000
